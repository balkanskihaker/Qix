{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "shell",
      "command": "g++",
      "args": [
        "-std=c++17",
        "-Wall",
        "-g",
        "${workspaceFolder}/src/main.cpp",
        "${workspaceFolder}/src/scenes/menu.cpp",
        "${workspaceFolder}/src/scenes/game.cpp",
        "${workspaceFolder}/src/scenes/scoreboard.cpp",
        "${workspaceFolder}/src/core/renderer.cpp",
        "${workspaceFolder}/src/core/grid.cpp",
        "${workspaceFolder}/src/entities/stix.cpp",
        "${workspaceFolder}/src/entities/sparx.cpp",
        "${workspaceFolder}/src/entities/qix.cpp",
        "${workspaceFolder}/src/core/gamestate.cpp",
        "${workspaceFolder}/src/core/levelmanager.cpp",
        "${workspaceFolder}/src/core/RgbImage.cpp",
        "-I${workspaceFolder}/src",
        "-framework", "OpenGL",
        "-framework", "GLUT",
        "-Wno-deprecated",
        "-o", "${workspaceFolder}/build/qix"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}